# =====================================================
# VoxFlow Voice Agent — environment configuration
# Copy to .env and fill in.
# =====================================================

# ---------- LLM ----------
# Pick one: ollama | groq | openrouter
LLM_PROVIDER=ollama

# Ollama (local, no key)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Groq (free tier — https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter (free tier — https://openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Common
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=512

# ---------- Voice ----------
# STT model size: tiny | base | small | medium | large-v3
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=auto  # auto | cpu | cuda
WHISPER_COMPUTE_TYPE=int8

# TTS voice (Hindi+English). Examples:
#   hi-IN-MadhurNeural     (Hindi male)
#   hi-IN-SwaraNeural      (Hindi female)
#   en-IN-NeerjaNeural     (English-India female)
#   en-IN-PrabhatNeural    (English-India male)
TTS_VOICE_HI=hi-IN-SwaraNeural
TTS_VOICE_EN=en-IN-NeerjaNeural
TTS_DEFAULT_LANG=hi

# ---------- API ----------
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# ---------- Database & Supabase ----------
# SQLite for local dev: sqlite:///./voxflow.db
# Postgres/Supabase for production: postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=sqlite:///./voxflow.db
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWKS_URL=https://[YOUR-PROJECT-REF].supabase.co/auth/v1/.well-known/jwks.json

# ---------- Logging ----------
LOG_LEVEL=INFO

# ---------- Business ----------
BUSINESS_NAME=VoxFlow
BUSINESS_TIMEZONE=Asia/Kolkata
